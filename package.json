    "jspdf": "^4.2.1",
    "katex": "^0.17.0",
    "lucide-react": "^0.546.0",
    "mongoose": "^9.7.3",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-markdown": "^10.1.0",
