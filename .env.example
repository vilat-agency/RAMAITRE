# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# VITE_API_URL: Base URL for the backend API, used by the client-side app.
# If running as a native Android APK, set this to your deployed backend URL
# (ex: https://ton-app.up.railway.app). SANS cette variable, l'app Android
# ne peut joindre aucune route /api/* et affichera "Failed to fetch".
VITE_API_URL=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# MONGODB_URI: Connection string for MongoDB (Atlas ou local).
MONGODB_URI="mongodb://localhost:27017/ramaitre"

# SESSION_SECRET: Secret utilisé pour signer les cookies de session.
# REQUIS en production. Génère une chaîne longue et aléatoire, ex:
# openssl rand -base64 32
SESSION_SECRET="change-me-to-a-long-random-string"
